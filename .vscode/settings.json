{
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true
  },
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  "eslint.ignorePath": ".eslintignore",
  "editor.renderRichScreenReaderContent": true,
  "editor.renderLineHighlightOnlyWhenFocus": true,
  "editor.scrollbar.scrollByPage": true,
  "editor.scrollOnMiddleClick": true
}