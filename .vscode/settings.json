{
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true
  },
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  "eslint.ignorePath": ".eslintignore",
  "editor.renderRichScreenReaderContent": true,
  "editor.renderLineHighlightOnlyWhenFocus": true,
  "editor.scrollbar.scrollByPage": true,
  "editor.scrollOnMiddleClick": true,
  "editor.autoIndentOnPaste": true,
  "editor.codeActions.triggerOnFocusChange": true,
  "editor.columnSelection": false,
  "editor.experimental.asyncTokenizationLogging": true,
  "editor.experimental.preferTreeSitter.typescript": true,
  "editor.gotoLocation.alternativeReferenceCommand": "editor.action.goToReferences",
  "editor.selectionHighlightMultiline": true,
  "editor.smoothScrolling": true,
  "github-actions.workflows.pinned.refresh.enabled": true,
  "vscode-edge-devtools.browserFlavor": "Default",
  "vscode-edge-devtools.showWorkers": true,
  "vscode-edge-devtools.webhintInstallNotification": true,
  "editor.formatOnPaste": true,
  "githubIssues.alwaysPromptForNewIssueRepo": true,
  "npm-intellisense.packageSubfoldersIntellisense": true,
  "npm-intellisense.scanDevDependencies": true,
  "npm-intellisense.showBuildInLibs": true,
  "eslint.debug": true,
  "eslint.lintTask.enable": true,
  "copilot-toolbox.thinkingMachineMode.appendNotepad": true,
  "copilot-toolbox.thinkingMachineMode.enabled": true,
  "copilot-toolbox.thinkingMachineMode.runAwarenessScan": true,
  "copilot-toolbox.thinkingMachineMode.mergeAwarenessIntoCopilotInstructions": true,
  "copilot-toolbox.thinkingMachineMode.showConfirmationModal": true,
  "copilot-toolbox.thinkingMachineMode.useSeparateContextPackDefaults": true,
  "copilot-toolbox.thinkingMachineMode.includeGit": true,
  "copilot-toolbox.thinkingMachineMode.includeDiagnostics": true,
  "copilot-toolbox.thinkingMachineMode.openChat": true,
  "copilot-toolbox.oneClickSetup.mergeClaudeLocalMd": false,
  "copilot-toolbox.oneClickSetup.migrateSkillsTarget": "user",
  "copilot-toolbox.oneClickSetup.migrateClaudeSkillsTarget": "user",
  "copilot-toolbox.intelligence.includeGitByDefault": true,
  "copilot-toolbox.intelligence.openChatAfterPack": true
}