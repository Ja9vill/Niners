rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Helpers
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isEmail(email) {
      return isSignedIn() && 
        request.auth.token != null && 
        request.auth.token.email == email;
    }
    
    function hasRole(role) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/hosts/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/hosts/$(request.auth.uid)).data.role == role;
    }

    function isDirector() {
      return isEmail("jwavpr@gmail.com") || hasRole("Director");
    }

    // PUBLIC READ for standard entities to support talent login and roster view
    
    match /hosts/{id} {
      allow get, list: if true;
      allow write: if isDirector();
    }

    match /commissions/{id} {
      allow get, list: if true;
      allow write: if isDirector();
    }

    match /notes/{id} {
      allow read: if true;
      allow write: if isDirector();
    }

    match /pk_records/{id} { 
      allow read: if true; 
      allow write: if isDirector(); 
    }
    
    match /exposures/{id} { 
      allow read: if true; 
      allow write: if isDirector(); 
    }
    
    match /fanbase_health/{id} { 
      allow read: if true; 
      allow write: if isDirector(); 
    }
    
    match /tasks/{id} { 
      allow read: if true; 
      allow write: if isDirector(); 
    }
    
    match /goals/{id} { 
      allow read: if true; 
      allow write: if isDirector(); 
    }
    
    match /calendar/{id} { 
      allow read: if true; 
      allow write: if isDirector(); 
    }

    match /reset_requests/{id} {
      allow read, create: if true;
      allow update, delete: if isDirector();
    }
  }
}
