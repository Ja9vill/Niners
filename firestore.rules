rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    
    function isDirector() { 
      return isSignedIn() && (
        request.auth.token.email == "jwavpr@gmail.com" || 
        (exists(/databases/$(database)/documents/hosts/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/hosts/$(request.auth.uid)).data.role == "Director")
      ); 
    }

    // PUBLIC READ for standard entities to support talent login and roster view
    // (In a more restrictive production environment, we would narrow this down)
    
    match /hosts/{id} {
      allow read: if true;
      allow write: if isDirector();
    }

    match /commissions/{id} {
      allow read: if true;
      allow write: if isDirector();
    }

    match /notes/{id} {
      allow read: if true;
      allow write: if isDirector();
    }

    match /pk_records/{id} { allow read: if true; allow write: if isDirector(); }
    match /exposures/{id} { allow read: if true; allow write: if isDirector(); }
    match /fanbase_health/{id} { allow read: if true; allow write: if isDirector(); }
    match /tasks/{id} { allow read: if true; allow write: if isDirector(); }
    match /goals/{id} { allow read: if true; allow write: if isDirector(); }
    match /calendar/{id} { allow read: if true; allow write: if isDirector(); }

    match /reset_requests/{id} {
      allow read, create: if true;
      allow update, delete: if isDirector();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
