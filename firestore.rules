rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for auth status and roles
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function getRole() {
      return isSignedIn() && request.auth.token != null && request.auth.token.role != null ? request.auth.token.role : '';
    }
    
    function isDirector() {
      return getRole() == 'director' || getRole() == 'Director';
    }
    
    function isHeadAdmin() {
      return getRole() == 'head admin' || getRole() == 'Head Admin';
    }
    
    function isAdmin() {
      return getRole() == 'admin' || getRole() == 'Admin';
    }
    
    function isManager() {
      return getRole() == 'manager' || getRole() == 'Manager';
    }
    
    function isAgent() {
      return getRole() == 'agent' || getRole() == 'Agent';
    }
    
    function isHost() {
      return getRole() == 'host' || getRole() == 'Host' || getRole() == 'talent' || getRole() == 'Talent';
    }
    
    function isLeadership() {
      return isDirector() || isHeadAdmin();
    }
    
    function isStaff() {
      return isLeadership() || isAdmin() || isManager() || isAgent();
    }

    // 1. users Collection Rules
    match /users/{userId} {
      // Leadership/Admin can read all profiles. Managers/Agents can read themselves or users assigned to them.
      // Hosts can read their own profile.
      allow read: if true;
      
      // Directors & Head Admins can do any write
      // The user themselves can update their profile, but cannot escalate their own role or change critical fields
      allow create: if isLeadership();
      allow update: if isLeadership() || (
        isSignedIn() && request.auth.uid == userId &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.poppoId == resource.data.poppoId &&
        (resource.data.assignedManagerId == null ? request.resource.data.assignedManagerId == null : request.resource.data.assignedManagerId == resource.data.assignedManagerId)
      );
      allow delete: if isLeadership();
    }

    // 2. performance_reports Collection Rules
    match /performance_reports/{reportId} {
      allow read: if isStaff() || (isSignedIn() && resource.data.poppoId == request.auth.uid);
      allow write: if isLeadership() || isAdmin();
    }

    // 3. fanbase_reports Collection Rules
    match /fanbase_reports/{reportId} {
      allow read: if isStaff() || (isSignedIn() && resource.data.poppoId == request.auth.uid);
      
      // Leadership & Admins can write any report
      // Hosts can create (submit) their own fanbase reports
      allow create: if isLeadership() || isAdmin() || (
        isHost() && 
        request.resource.data.poppoId == request.auth.uid &&
        request.resource.data.reporterId == request.auth.uid
      );
      allow update, delete: if isLeadership() || isAdmin();
    }

    // 4. pk_reports Collection Rules
    match /pk_reports/{reportId} {
      allow read: if isStaff() || (isSignedIn() && resource.data.poppoId == request.auth.uid);
      
      // Leadership & Admins can write any report
      // Hosts can create (submit) their own PK reports
      allow create: if isLeadership() || isAdmin() || (
        isHost() && 
        request.resource.data.poppoId == request.auth.uid &&
        request.resource.data.reporterId == request.auth.uid
      );
      allow update, delete: if isLeadership() || isAdmin();
    }

    // 5. events Collection Rules
    match /events/{eventId} {
      // Hidden events (marked as Director Only) can only be read by Directors
      allow read: if isDirector() || (
        isSignedIn() && 
        (!resource.data.keys().hasAll(['visibility']) || resource.data.visibility != 'Director Only') &&
        (!resource.data.keys().hasAll(['eventType']) || resource.data.eventType != 'Director Only')
      );
      
      // Directors, Head Admins, Admins, and Managers can write events
      allow write: if isLeadership() || isAdmin() || isManager();
    }

    // 6. tasks Collection Rules
    match /tasks/{taskId} {
      // Staff can read all tasks. Assignee can read tasks assigned to them
      allow read: if isStaff() || (isSignedIn() && resource.data.assigneeId == request.auth.uid);
      
      // Leadership & Admins can perform any write
      // Managers & Agents can write (create/update) tasks they assigned
      // Hosts can only update the status field of tasks assigned to them
      allow create: if isLeadership() || isAdmin() || (
        (isManager() || isAgent()) && 
        request.resource.data.assignerId == request.auth.uid
      );
      allow update: if isLeadership() || isAdmin() || (
        (isManager() || isAgent()) && 
        resource.data.assignerId == request.auth.uid && 
        request.resource.data.assignerId == request.auth.uid
      ) || (
        isHost() &&
        resource.data.assigneeId == request.auth.uid &&
        request.resource.data.assigneeId == resource.data.assigneeId &&
        request.resource.data.taskId == resource.data.taskId &&
        request.resource.data.assignerId == resource.data.assignerId &&
        request.resource.data.title == resource.data.title &&
        request.resource.data.content == resource.data.content &&
        request.resource.data.taskType == resource.data.taskType &&
        request.resource.data.dueDate == resource.data.dueDate &&
        request.resource.data.createdAt == resource.data.createdAt
      );
      allow delete: if isLeadership() || isAdmin() || (
        (isManager() || isAgent()) && 
        resource.data.assignerId == request.auth.uid
      );
    }

    // 7. commissions Collection Rules
    match /commissions/{commissionId} {
      allow read: if isStaff() || (isSignedIn() && (resource == null || resource.data.poppo_id == request.auth.uid));
      allow write: if isLeadership() || isAdmin();
    }

    // 8. pk_records Collection Rules
    match /pk_records/{recordId} {
      allow read: if isStaff() || (isSignedIn() && (resource == null || resource.data.poppo_id == request.auth.uid));
      allow write: if isLeadership() || isAdmin();
    }

    // 9. exposures Collection Rules
    match /exposures/{exposureId} {
      allow read: if isStaff() || (isSignedIn() && (resource == null || resource.data.poppo_id == request.auth.uid));
      allow write: if isLeadership() || isAdmin();
    }

    // 10. weekly_live_data & monthly_live_data Rules
    match /weekly_live_data/{id} {
      allow read: if isStaff() || (isSignedIn() && (resource == null || resource.data.poppo_id == request.auth.uid));
      allow write: if isLeadership() || isAdmin();
    }
    match /monthly_live_data/{id} {
      allow read: if isStaff() || (isSignedIn() && (resource == null || resource.data.poppo_id == request.auth.uid));
      allow write: if isLeadership() || isAdmin();
    }

    // 11. fanbase_health Collection Rules
    match /fanbase_health/{id} {
      allow read: if isStaff() || (isSignedIn() && (resource == null || resource.data.hostId == request.auth.uid));
      allow write: if isLeadership() || isAdmin() || isManager() || isAgent();
    }

    // 12. goals Collection Rules
    match /goals/{goalId} {
      allow read: if isStaff() || (isSignedIn() && (resource == null || resource.data.hostId == request.auth.uid));
      allow write: if isLeadership() || isAdmin() || isManager() || isAgent();
    }

    // 13. calendar Collection Rules (private)
    match /calendar/{eventId} {
      allow read: if isDirector() || (
        isSignedIn() && 
        (!resource.data.keys().hasAll(['visibility']) || resource.data.visibility != 'Director Only') &&
        (!resource.data.keys().hasAll(['eventType']) || resource.data.eventType != 'Director Only')
      );
      allow write: if isLeadership() || isAdmin() || isManager();
    }

    // 14. livehouse_requests Collection Rules
    match /livehouse_requests/{requestId} {
      allow read: if isStaff() || (isSignedIn() && (resource == null || resource.data.poppoId == request.auth.uid));
      allow write: if isLeadership() || isAdmin() || isHost();
    }

    // 15. reset_requests Collection Rules
    match /reset_requests/{requestId} {
      allow read: if isLeadership() || isAdmin();
      allow write: if isLeadership() || isAdmin() || isHost() || isSignedIn();
    }

    // 16. notes Collection Rules
    match /notes/{noteId} {
      allow read: if isStaff() || (isSignedIn() && (resource == null || resource.data.hostId == request.auth.uid));
      allow write: if isLeadership() || isAdmin() || isManager() || isAgent();
    }

    // 17. top_niners_earnings_summary Collection Rules
    match /top_niners_earnings_summary/{summaryId} {
      allow read: if isSignedIn();
      allow write: if isLeadership() || isAdmin();
    }

    // 18. events_calendar_public Collection Rules
    match /events_calendar_public/{eventId} {
      allow read: if isSignedIn();
      allow write: if isLeadership() || isAdmin() || isManager();
    }

    // 19. reporting_submissions Collection Rules
    match /reporting_submissions/{submissionId} {
      allow read: if isStaff() || (isSignedIn() && (resource == null || resource.data.submittedByUserId == request.auth.uid));
      allow write: if isStaff() || (isSignedIn() && (request.resource.data.submittedByUserId == request.auth.uid));
    }

    // 20. activity_audit_logs Collection Rules
    match /activity_audit_logs/{logId} {
      allow read: if isLeadership() || isAdmin();
      allow write: if isSignedIn();
    }

    // 21. system_logs Collection Rules
    match /system_logs/{logId} {
      allow read: if isLeadership();
      allow write: if isSignedIn();
    }

    // Default Deny: block all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
