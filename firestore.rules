rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for auth status and roles
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function getRole() {
      return isSignedIn() ? (
        request.auth.token != null && request.auth.token.role != null ? request.auth.token.role : 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : '')
      ) : '';
    }
    
    function isDirector() {
      return getRole() == 'Director' || getRole() == 'director';
    }
    
    function isHeadAdmin() {
      return getRole() == 'Head Admin' || getRole() == 'head admin' || getRole() == 'head_admin' || getRole() == 'Head_Admin';
    }
    
    function isAdmin() {
      return getRole() == 'Admin' || getRole() == 'admin';
    }
    
    function isManager() {
      return getRole() == 'Manager' || getRole() == 'manager';
    }
    
    function isAgent() {
      return getRole() == 'Agent' || getRole() == 'agent';
    }
    
    function isHost() {
      return getRole() == 'Host' || getRole() == 'host' || getRole() == 'Talent' || getRole() == 'talent';
    }
    
    function isLeadership() {
      return isDirector() || isHeadAdmin();
    }
    
    function isStaff() {
      return isLeadership() || isAdmin() || isManager() || isAgent();
    }

    function isNotLocked() {
      return resource == null || !resource.data.keys().hasAll(['isLocked']) || resource.data.isLocked != true;
    }

    // 0. staging_queue Collection Rules
    match /staging_queue/{queueId} {
      allow read: if isStaff();
      allow create: if isSignedIn();
      allow update, delete: if isLeadership();
    }

    // 1. users Collection Rules
    match /users/{userId} {
      allow read: if true;
      allow create: if isLeadership();
      allow update: if isLeadership() || (
        isSignedIn() && request.auth.uid == userId &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.poppoId == resource.data.poppoId
      );
      allow delete: if isLeadership();
    }

    // Role-based document collections
    match /host/{userId} {
      allow read: if true;
      allow create, delete: if isLeadership();
      allow update: if isLeadership() || (isSignedIn() && request.auth.uid == userId);

      match /host_awards/{awardId} {
        allow read: if isSignedIn();
        allow write: if isDirector() || isHeadAdmin() || isLeadership();
      }
    }
    match /manager/{userId} {
      allow read: if true;
      allow create, delete: if isLeadership();
      allow update: if isLeadership() || (isSignedIn() && request.auth.uid == userId);
    }
    match /admin/{userId} {
      allow read: if true;
      allow create, delete: if isLeadership();
      allow update: if isLeadership() || (isSignedIn() && request.auth.uid == userId);
    }
    match /head_admin/{userId} {
      allow read: if true;
      allow create, delete: if isLeadership();
      allow update: if isLeadership() || (isSignedIn() && request.auth.uid == userId);
    }
    match /agent/{userId} {
      allow read: if true;
      allow create, delete: if isLeadership();
      allow update: if isLeadership() || (isSignedIn() && request.auth.uid == userId);
    }
    match /director/{userId} {
      allow read: if true;
      allow create, delete: if isLeadership();
      allow update: if isLeadership() || (isSignedIn() && request.auth.uid == userId);
    }

    // Profile collections (new DB schema)
    match /host_profile/{userId} {
      allow read: if true;
      allow write: if isStaff();
    }
    match /manager_profile/{userId} {
      allow read: if true;
      allow write: if isStaff();
    }
    match /admin_profile/{userId} {
      allow read: if true;
      allow write: if isStaff();
    }
    match /head_admin_profile/{userId} {
      allow read: if true;
      allow write: if isStaff();
    }
    match /agent_profile/{userId} {
      allow read: if true;
      allow write: if isStaff();
    }
    match /director_profile/{userId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // 2. performance_reports Collection Rules
    match /performance_reports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isLeadership() || isAdmin();
    }
    match /performance_weekly_reports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isLeadership() || isAdmin();
    }
    match /user_performance_reports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isLeadership() || isAdmin();
    }
    match /director_performance_reports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isLeadership() || isAdmin();
    }

    // 3. fanbase_reports Collection Rules
    match /fanbase_reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isLeadership() || (isAdmin() && isNotLocked());
    }

    // 4. pk_reports Collection Rules
    match /pk_reports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 5. attendance Collection Rules
    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 6. calendar Collection Rules
    match /calendar/{eventId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 7. events Collection Rules
    match /events/{eventId} {
      allow read: if isDirector() || (
        isSignedIn() && 
        (!resource.data.keys().hasAll(['visibility']) || resource.data.visibility != 'Director Only') &&
        (!resource.data.keys().hasAll(['eventType']) || resource.data.eventType != 'Director Only')
      );
      allow write: if isSignedIn();
    }

    // 8. announcements Collection Rules
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isDirector() || isHeadAdmin();
    }

    // 9. tasks Collection Rules
    match /tasks/{taskId} {
      allow read: if isStaff() || (isSignedIn() && resource.data.assigneeId == request.auth.uid);
      allow create: if isLeadership() || isAdmin() || (
        (isManager() || isAgent()) && 
        request.resource.data.assignerId == request.auth.uid
      );
      allow update: if isLeadership() || isAdmin() || (
        (isManager() || isAgent()) && 
        resource.data.assignerId == request.auth.uid
      ) || (
        isHost() &&
        resource.data.assigneeId == request.auth.uid
      );
      allow delete: if isLeadership() || isAdmin() || (
        (isManager() || isAgent()) && 
        resource.data.assignerId == request.auth.uid
      );
    }

    // 10. Awards & Assignments
    match /awards/{awardId} {
      allow read: if isSignedIn();
      allow write: if isDirector() || isHeadAdmin() || isLeadership();
    }
    match /host_awards/{awardId} {
      allow read: if isSignedIn();
      allow write: if isDirector() || isHeadAdmin() || isLeadership();
    }
    match /award_assignments/{assignmentId} {
      allow read: if isSignedIn();
      allow write: if isDirector() || isHeadAdmin() || isLeadership();
    }

    // 11. Progress Notes
    match /notes/{noteId} {
      allow read, write: if isDirector() || isHeadAdmin() || isLeadership() || isStaff();
    }

    // 12. Host Intake Requests
    match /host_requests/{requestId} {
      allow read: if isDirector() || isHeadAdmin() || isLeadership() || isStaff();
      allow create: if isStaff() || isDirector() || isHeadAdmin() || isLeadership();
      allow update, delete: if isDirector() || isHeadAdmin() || isLeadership();
    }

    // 13. Director specific collections
    match /activity_logs/{logId} {
      allow read, write: if isLeadership();
    }
    match /activity_audit_logs/{logId} {
      allow read, write: if isLeadership();
    }
    match /system_logs/{logId} {
      allow read, write: if isLeadership();
    }
    match /earnings_summaries/{summaryId} {
      allow read, write: if isLeadership();
    }
    match /financials_monthly/{docId} {
      allow read, write: if isLeadership();
    }
    match /financials_weekly/{docId} {
      allow read, write: if isLeadership();
    }

    // 14. Livehouse Schedule
    match /livehouse_schedule/{scheduleId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
    match /livehouse_requests/{requestId} {
      allow read: if isSignedIn();
      allow write: if isStaff() || (isSignedIn() && request.resource.data.poppoId == request.auth.uid);
    }

    // 15. Livehouse Logs & System config
    match /livehouse_logs/{logId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // 16. Agent Financials
    match /agent_financials_monthly/{docId} {
      allow read, write: if isStaff();
    }
    match /agent_financials_weekly/{docId} {
      allow read, write: if isStaff();
    }

    // 17. Stream Notifications
    match /stream_notifications/{streamId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Default Deny: block all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
